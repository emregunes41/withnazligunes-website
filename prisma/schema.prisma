generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  password      String?
  emailVerified DateTime?
  image         String?
  gender        String?
  age           Int?
  phone         String?
  role          String    @default("MEMBER")
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts      Account[]
  sessions      Session[]
  purchases     Purchase[]
  reservations  Reservation[]
}

model Purchase {
  id            String   @id @default(cuid())
  userId        String
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  productName   String
  productType   String
  price         String
  purchaseDate  DateTime @default(now())
  status        String   @default("COMPLETED")
}

model PhotographyPackage {
  id          String   @id @default(cuid())
  name        String
  description String
  price       String
  category    String   @default("STANDARD")
  timeType    String   @default("FULL_DAY")
  maxCapacity Int      @default(1)
  features    String[]
  addons      Json?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  reservations Reservation[] @relation("PackageToReservation")
}

model Reservation {
  id                 String               @id @default(cuid())
  brideName          String
  bridePhone         String
  brideEmail         String
  groomName          String?
  groomPhone         String?
  groomEmail         String?
  eventDate          DateTime
  eventTime          String?
  status             String               @default("PENDING")
  paymentStatus      String               @default("UNPAID")
  totalAmount        String?
  paidAmount         String?
  selectedAddons     Json?
  notes              String?
  createdAt          DateTime             @default(now())
  updatedAt          DateTime             @updatedAt
  userId             String?
  user               User?                @relation(fields: [userId], references: [id])
  packages           PhotographyPackage[] @relation("PackageToReservation")
}

model Account {
  id                 String  @id @default(cuid())
  userId             String
  type               String
  provider           String
  providerAccountId  String
  refresh_token      String? @db.Text
  access_token       String? @db.Text
  expires_at         Int?
  token_type         String?
  scope              String?
  id_token           String? @db.Text
  session_state      String?
  user               User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Admin {
  id        String   @id @default(cuid())
  username  String   @unique
  password  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
