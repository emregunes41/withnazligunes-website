generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Admin {
  id        String   @id @default(cuid())
  username  String   @unique
  password  String   // Hashed password
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model PhotographyPackage {
  id          String        @id @default(cuid())
  name        String
  description String
  price       String
  category    String        @default("STANDARD") // STANDARD, EXTERIOR, VIDEO
  timeType    String        @default("FULL_DAY") // FULL_DAY, SLOT, MORNING, EVENING
  maxCapacity Int           @default(1)
  features    String[]
  addons      Json?                         // Array of { id, title, price }
  isActive    Boolean       @default(true)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  reservations Reservation[]
}

model Reservation {
  id            String   @id @default(cuid())
  brideName     String
  bridePhone    String
  brideEmail    String
  groomName     String?
  groomPhone    String?
  groomEmail    String?
  eventDate     DateTime
  eventTime     String? // Format HH:mm
  packageId     String
  status        String   @default("PENDING") // PENDING, CONFIRMED, CANCELLED, COMPLETED
  contractLog   String?  // IP/Timestamp of contract approval
  paymentStatus String   @default("UNPAID")  // UNPAID, DEPOSIT_PAID, PAID
  totalAmount   String?  // Total price (package + addons)
  paidAmount    String?  // Amount paid in this transaction
  selectedAddons Json?   // [{ title, price }]
  notes         String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  package       PhotographyPackage @relation(fields: [packageId], references: [id])
}
